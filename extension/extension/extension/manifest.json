{
  "manifest_version": 3,
  "name": "SecureCloud Wallet",
  "version": "2.1",
  "description": "Gestion sécurisée de vos clés RSA pour le cloud chiffré",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://quickchart.io/"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["inpage.js"],
      "matches": [
        "https://*/*",
        "http://*/*"
      ]
    }
  ]
}